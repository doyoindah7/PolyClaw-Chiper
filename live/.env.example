# /live/.env.example — Template (SAFE to commit)
# =====================================================
# Copy this file to .env and fill in your REAL values.
# NEVER commit .env — it contains your private key!
#
#   cp .env.example .env
#   nano .env  # fill in values
#
# =====================================================

# === WALLET (CRITICAL — NEVER SHARE) ===
# Generate via: python live/wallet/generate_wallet.py
# Must start with 0x + 64 hex chars
WALLET_PRIVATE_KEY=0x_REPLACE_WITH_YOUR_PRIVATE_KEY_

# Wallet address (public, derived from private key)
WALLET_ADDRESS=0x_REPLACE_WITH_YOUR_WALLET_ADDRESS

# === POLYGON RPC ===
# Primary: Alchemy (free tier 660 req/min — register at alchemy.com)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
# Fallback: Infura or QuickNode (optional but recommended)
POLYGON_RPC_FALLBACK_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_API_KEY

# === POLYMARKET CLOB ===
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/
CHAIN_ID=137

# === CONTRACTS (FIXED — DO NOT CHANGE) ===
# These are official Polymarket contract addresses on Polygon mainnet.
CTF_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E
CONDITIONAL_TOKENS_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
USDC_ADDRESS=0x2791bca1f2de4661ed88a30c99a7a9449aa84174
NEGATIVE_RISK_ADAPTER_ADDRESS=0xE5407fE24858D1c01c2Be6d19B5213a7dB5b4F40

# === CLOB API CREDENTIALS (derived via L1 signature) ===
# Generate via: python live/wallet/derive_api_key.py
# These are NOT your private key — they're API auth tokens.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# === GAS STRATEGY ===
GAS_STRATEGY=fast
MAX_GAS_PRICE_GWEI=500

# === TRADING PARAMS ($15 micro-test) ===
BOT_MODE=live
INITIAL_BANKROLL_USD=15.00
MAX_POSITION_USD=3.00
MAX_OPEN_POSITIONS=2
EMERGENCY_STOP_LOSS_USD=5.00

# === SAFETY ===
KILL_SWITCH=false
MANUAL_CONFIRM_THRESHOLD_USD=20.00

# === HTTP SERVER (live dashboard, separate port from paper) ===
HTTP_HOST=0.0.0.0
HTTP_PORT=8085

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FORMAT=json
